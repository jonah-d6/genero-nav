{
  "name": "genero-nav",
  "displayName": "genero-nav",
  "description": "",
  "version": "0.0.5",
  "repository": {
    "type": "git",
    "url": "https://github.com/jonah-d6/genero-nav.git"
  },
  "engines": {
    "vscode": "^1.108.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "genero-nav.nextFunction",
        "title": "Genero: Go to Next Function"
      },
      {
        "command": "genero-nav.previousFunction",
        "title": "Genero: Go to Previous Function"
      },
      {
        "command": "genero-nav.nextTestSection",
        "title": "Genero: Go to Next Test Section"
      },
      {
        "command": "genero-nav.previousTestSection",
        "title": "Genero: Go to Previous Test Section"
      },
      {
        "command": "genero-nav.nextRegion",
        "title": "Genero: Go to Next Region"
      },
      {
        "command": "genero-nav.previousRegion",
        "title": "Genero: Go to Previous Region"
      },
      {
        "command": "genero-nav.selectToNextFunction",
        "title": "Genero: Select to Next Function"
      },
      {
        "command": "genero-nav.selectToPreviousFunction",
        "title": "Genero: Select to Previous Function"
      },
      {
        "command": "genero-nav.selectToNextTestSection",
        "title": "Genero: Select to Next Test Section"
      },
      {
        "command": "genero-nav.selectToPreviousTestSection",
        "title": "Genero: Select to Previous Test Section"
      },
      {
        "command": "genero-nav.selectToNextRegion",
        "title": "Genero: Select to Next Region"
      },
      {
        "command": "genero-nav.selectToPreviousRegion",
        "title": "Genero: Select to Previous Region"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.108.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "license": "MIT"
}
